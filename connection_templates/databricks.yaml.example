# Connection Template: Databricks SQL + Genie MCP
# Copy to .knowledge/datasets/{name}/manifest.yaml and fill in values.
#
# Credentials resolution order for access_token:
#   1. Explicit value in connection.access_token (not recommended — use profile instead)
#   2. DATABRICKS_TOKEN env var
#   3. ~/.databrickscfg profile named in connection.databricks_profile

dataset_id: "{dataset_id}"
display_name: "{Display Name}"
description: "{Brief description of the dataset}"
domain: "{e-commerce|saas|fintech|marketplace|other}"
created_at: "{YYYY-MM-DD}"
is_seed: false

connection:
  type: databricks
  server_hostname: "{workspace}.cloud.databricks.com"   # or env: DATABRICKS_SERVER_HOSTNAME
  http_path: "/sql/1.0/warehouses/{warehouse_id}"       # or env: DATABRICKS_HTTP_PATH
  access_token: null                                     # leave null to use profile below
  databricks_profile: "databricks-sql"                  # profile in ~/.databrickscfg
  catalog: "{catalog}"      # e.g. hive_metastore — leave null for default
  schema: "{schema}"        # SQL schema prefix for queries

mcp:
  enabled: true
  genie_space_id: "{genie_space_id}"   # natural-language query via Genie
  system_ai: true                       # enables python_exec and other system/ai tools

summary:
  table_count: null
  total_rows: null
  date_range: null
  primary_entities: []
  key_dimensions: []
  last_profiled: null

local_data:
  path: "data/{dataset_id}/"
  duckdb: null   # Databricks does not use local DuckDB

status: active
last_used: null
analysis_count: 0
